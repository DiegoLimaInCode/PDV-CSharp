<UserControl
    x:Class="PDVCSharp.WPF.Sections.Venda"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:PDVCSharp.WPF.Sections"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:PDVCSharp.WPF.ViewModels"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <UserControl.DataContext>
        <vm:VendaViewModel />
    </UserControl.DataContext>

    <Grid Background="#E8E8E8">
        <!--  Cabeçalho  -->
        <Border
            Height="35"
            VerticalAlignment="Top"
            Background="#3A3A3A">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="12"
                    FontWeight="Normal"
                    Foreground="White"
                    Text="CAIXA - 01" />

                <TextBlock
                    Grid.Column="1"
                    Margin="0,0,5,0"
                    VerticalAlignment="Center"
                    FontSize="10"
                    Foreground="White"
                    Text="📶" />

                <TextBlock
                    x:Name="TxtHora"
                    Grid.Column="2"
                    Margin="0,0,10,0"
                    VerticalAlignment="Center"
                    FontSize="10"
                    Foreground="White"
                    Text="{Binding Now, Mode=OneWay, StringFormat={}{0:HH:mm}}" />
            </Grid>
        </Border>

        <!--  Título da Seção  -->
        <StackPanel
            Margin="15,50,0,0"
            VerticalAlignment="Top"
            Orientation="Horizontal">
            <TextBlock
                Margin="0,0,8,0"
                FontSize="20"
                Foreground="#2151A1"
                Text="🛒" />

            <TextBlock
                VerticalAlignment="Center"
                FontSize="16"
                FontWeight="Bold"
                Foreground="#2151A1"
                Text="SUPERMARKET" />

            <TextBlock
                Margin="5,0,0,0"
                VerticalAlignment="Center"
                FontSize="16"
                FontWeight="Normal"
                Foreground="#0F3266"
                Text=" - Venda em andamento" />
        </StackPanel>

        <!--  Container Principal com Grid  -->
        <Grid Margin="15,90,15,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="200" />
            </Grid.ColumnDefinitions>

            <!--  Lista de Produtos  -->
            <ScrollViewer
                Grid.Column="0"
                Margin="0,0,15,0"
                HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!--  Produto 1: Leite  -->
                    <Border
                        Margin="0,0,0,10"
                        Padding="12"
                        Background="White"
                        BorderBrush="#D0D0D0"
                        BorderThickness="1"
                        CornerRadius="5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!--  Imagem do Produto  -->
                            <Border
                                Width="50"
                                Height="50"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Background="White"
                                BorderBrush="#E0E0E0"
                                BorderThickness="1">
                                <Image
                                    Margin="3"
                                    Source="/Components/13764-5268fa3a-removebg-preview.png"
                                    Stretch="Uniform" />
                            </Border>

                            <!--  Informações do Produto  -->
                            <StackPanel
                                Grid.Column="1"
                                Margin="12,0,0,0"
                                VerticalAlignment="Center">
                                <TextBlock
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    Text="Leite Integral Piracanjuba 1L" />
                                <TextBlock
                                    Margin="0,2,0,0"
                                    FontSize="11"
                                    Foreground="#666666"
                                    Text="67239238579326| R$ 4,59 ×2" />
                            </StackPanel>

                            <!--  Controles de Quantidade  -->
                            <StackPanel
                                Grid.Column="2"
                                Margin="10,0,10,0"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                                <Button
                                    Width="25"
                                    Height="25"
                                    Padding="0"
                                    Background="White"
                                    BorderBrush="#C0C0C0"
                                    BorderThickness="1"
                                    Content="−"
                                    FontSize="14" />
                                <TextBlock
                                    Width="25"
                                    Margin="8,0,8,0"
                                    VerticalAlignment="Center"
                                    FontSize="13"
                                    Text="2"
                                    TextAlignment="Center" />
                                <Button
                                    Width="25"
                                    Height="25"
                                    Padding="0"
                                    Background="White"
                                    BorderBrush="#C0C0C0"
                                    BorderThickness="1"
                                    Content="+"
                                    FontSize="14" />
                            </StackPanel>

                            <!--  Preço  -->
                            <TextBlock
                                Grid.Column="3"
                                Margin="10,0,10,0"
                                VerticalAlignment="Center"
                                FontSize="14"
                                FontWeight="Bold"
                                Text="R$ 9,18" />

                            <!--  Botão Remover  -->
                            <Button
                                Grid.Column="4"
                                Width="25"
                                Height="25"
                                Padding="0"
                                VerticalAlignment="Center"
                                Background="Transparent"
                                BorderThickness="0"
                                Content="🗑️"
                                FontSize="14" />
                        </Grid>
                    </Border>

                    <!--  Produto 2: Arroz  -->
                    <Border
                        Padding="12"
                        Background="White"
                        BorderBrush="#D0D0D0"
                        BorderThickness="1"
                        CornerRadius="5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!--  Imagem do Produto  -->
                            <Border
                                Width="50"
                                Height="50"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Background="White"
                                BorderBrush="#E0E0E0"
                                BorderThickness="1">
                                <Image
                                    Margin="3"
                                    Source="/Components/D_NQ_NP_950764-MLU73211786581_122023-O-removebg-preview.png"
                                    Stretch="Uniform" />
                            </Border>

                            <!--  Informações do Produto  -->
                            <StackPanel
                                Grid.Column="1"
                                Margin="12,0,0,0"
                                VerticalAlignment="Center">
                                <TextBlock
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    Text="Arroz Tio Joao 5Kg" />
                                <TextBlock
                                    Margin="0,2,0,0"
                                    FontSize="11"
                                    Foreground="#666666"
                                    Text="92385602760347| R$ 25,90 ×1" />
                            </StackPanel>

                            <!--  Controles de Quantidade  -->
                            <StackPanel
                                Grid.Column="2"
                                Margin="10,0,10,0"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                                <Button
                                    Width="25"
                                    Height="25"
                                    Padding="0"
                                    Background="White"
                                    BorderBrush="#C0C0C0"
                                    BorderThickness="1"
                                    Content="−"
                                    FontSize="14" />
                                <TextBlock
                                    Width="25"
                                    Margin="8,0,8,0"
                                    VerticalAlignment="Center"
                                    FontSize="13"
                                    Text="1"
                                    TextAlignment="Center" />
                                <Button
                                    Width="25"
                                    Height="25"
                                    Padding="0"
                                    Background="White"
                                    BorderBrush="#C0C0C0"
                                    BorderThickness="1"
                                    Content="+"
                                    FontSize="14" />
                            </StackPanel>

                            <!--  Preço  -->
                            <TextBlock
                                Grid.Column="3"
                                Margin="10,0,10,0"
                                VerticalAlignment="Center"
                                FontSize="14"
                                FontWeight="Bold"
                                Text="R$ 25,90" />

                            <!--  Botão Remover  -->
                            <Button
                                Grid.Column="4"
                                Width="25"
                                Height="25"
                                Padding="0"
                                VerticalAlignment="Center"
                                Background="Transparent"
                                BorderThickness="0"
                                Content="🗑️"
                                FontSize="14" />
                        </Grid>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!--  Painel Lateral Direito - Total e Botões  -->
            <Border
                Grid.Column="1"
                Padding="15"
                Background="White"
                BorderBrush="#D0D0D0"
                BorderThickness="1"
                CornerRadius="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!--  Informações de Total  -->
                    <StackPanel Grid.Row="0">
                        <TextBlock
                            Margin="0,0,0,8"
                            HorizontalAlignment="Center"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="#333333"
                            Text="TOTAL A PAGAR" />

                        <TextBlock
                            Margin="0,0,0,15"
                            HorizontalAlignment="Center"
                            FontSize="36"
                            FontWeight="Bold"
                            Foreground="#4169E1"
                            Text="R$ 35,08" />

                        <Border
                            Padding="0,12,0,0"
                            BorderBrush="#E0E0E0"
                            BorderThickness="0,1,0,0">
                            <StackPanel>
                                <Grid Margin="0,0,0,5">
                                    <TextBlock
                                        HorizontalAlignment="Left"
                                        FontSize="11"
                                        Foreground="#666666"
                                        Text="Subtotal:" />
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        FontSize="11"
                                        FontWeight="SemiBold"
                                        Text="R$ 35,08" />
                                </Grid>

                                <Grid>
                                    <TextBlock
                                        HorizontalAlignment="Left"
                                        FontSize="11"
                                        Foreground="#666666"
                                        Text="Desconto:" />
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        FontSize="11"
                                        FontWeight="SemiBold"
                                        Text="R$ 0,00" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!--  Espaço vazio no meio  -->
                    <Border Grid.Row="1" />

                    <!--  Botões de Ação  -->
                    <StackPanel Grid.Row="2" VerticalAlignment="Bottom">
                        <Button
                            Height="38"
                            Background="#4169E1"
                            BorderThickness="0"
                            Click="Button_Click"
                            Content="✓ FINALIZAR VENDA"
                            Cursor="Hand"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="White" />

                        <Button
                            Height="38"
                            Margin="0,8,0,0"
                            Background="#DC143C"
                            BorderThickness="0"
                            Click="Button_Click_2"
                            Content="✕ CANCELAR VENDA"
                            Cursor="Hand"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="White" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</UserControl>
