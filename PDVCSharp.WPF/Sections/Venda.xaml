<UserControl
    x:Class="PDVCSharp.WPF.Sections.Venda"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:PDVCSharp.WPF.Sections"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:PDVCSharp.WPF.ViewModels"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <UserControl.DataContext>
        <vm:VendaViewModel />
    </UserControl.DataContext>

    <Grid Background="#E8E8E8">
        <!--  Cabeçalho  -->
        <Border
            Height="35"
            VerticalAlignment="Top"
            Background="#3A3A3A">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="12"
                    FontWeight="Normal"
                    Foreground="White"
                    Text="CAIXA - 01" />

                <TextBlock
                    Grid.Column="1"
                    Margin="0,0,5,0"
                    VerticalAlignment="Center"
                    FontSize="10"
                    Foreground="White"
                    Text="📶" />

                <TextBlock
                    x:Name="TxtHora"
                    Grid.Column="2"
                    Margin="0,0,10,0"
                    VerticalAlignment="Center"
                    FontSize="10"
                    Foreground="White"
                    Text="{Binding Now, Mode=OneWay, StringFormat={}{0:HH:mm}}" />
            </Grid>
        </Border>

        <!--  Título da Seção  -->
        <StackPanel
            Margin="15,50,0,0"
            VerticalAlignment="Top"
            Orientation="Horizontal">
            <TextBlock
                Margin="0,0,8,0"
                FontSize="20"
                Foreground="#2151A1"
                Text="🛒" />

            <TextBlock
                VerticalAlignment="Center"
                FontSize="16"
                FontWeight="Bold"
                Foreground="#2151A1"
                Text="SUPERMARKET" />

            <TextBlock
                Margin="5,0,0,0"
                VerticalAlignment="Center"
                FontSize="16"
                FontWeight="Normal"
                Foreground="#0F3266"
                Text=" - Venda em andamento" />
        </StackPanel>

        <!--  Container Principal com Grid  -->
        <Grid Margin="15,90,15,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="200" />
            </Grid.ColumnDefinitions>

            <!--  Lista de Produtos  -->
            <ScrollViewer
                Grid.Column="0"
                Margin="0,0,15,0"
                HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto">

                <ListBox 
                    x:Name="LstProdutos"
                    BorderThickness="0"
                    Background="Transparent"
                    ItemsSource="{Binding Produtos}"
                    d:ItemsSource="{d:SampleData ItemCount=8}">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Margin" Value="0,0,0,8" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter />
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <!--  Produto  -->
                            <Border
                                Padding="12"
                                Background="White"
                                BorderBrush="#D0D0D0"
                                BorderThickness="1"
                                CornerRadius="5">
                                <Border.Effect>
                                    <DropShadowEffect
                                        BlurRadius="8"
                                        Direction="270"
                                        Opacity="0.15"
                                        ShadowDepth="2"
                                        Color="#000000" />
                                </Border.Effect>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!--  Imagem do Produto  -->
                                    <Border
                                        Width="50"
                                        Height="50"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Background="White"
                                        BorderBrush="#E0E0E0"
                                        BorderThickness="1"
                                        CornerRadius="5">
                                        <Image
                                            Margin="3"
                                            Source="{Binding ImagePath}"
                                            Stretch="Uniform" />
                                    </Border>

                                    <!--  Informações do Produto  -->
                                    <StackPanel
                                        Grid.Column="1"
                                        Margin="12,0,0,0"
                                        VerticalAlignment="Center">
                                        <TextBlock
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            Foreground="#333333"
                                            Text="{Binding Name}" />
                                        <StackPanel Margin="0,4,0,0" Orientation="Horizontal">
                                            <TextBlock
                                                FontSize="11"
                                                Foreground="#999999"
                                                Text="R$ " />
                                            <TextBlock
                                                FontSize="11"
                                                Foreground="#999999"
                                                Text="{Binding Price, StringFormat={}{0:F2}}" />
                                            <TextBlock
                                                Margin="8,0,0,0"
                                                FontSize="11"
                                                Foreground="#999999"
                                                Text=" × " />
                                            <TextBlock
                                                FontSize="11"
                                                Foreground="#999999"
                                                Text="{Binding Quantity, StringFormat={}{0:F2}}" />
                                        </StackPanel>
                                    </StackPanel>

                                    <!--  Controles de Quantidade  -->
                                    <StackPanel
                                        Grid.Column="2"
                                        Margin="10,0,10,0"
                                        VerticalAlignment="Center"
                                        Orientation="Horizontal">
                                        <Button
                                            x:Name="BtnDiminuir"
                                            Width="28"
                                            Height="28"
                                            Padding="0"
                                            Click="BtnDiminuir_Click"
                                            Cursor="Hand"
                                            FontSize="16"
                                            FontWeight="Bold"
                                            Tag="{Binding}">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Background" Value="#F5F5F5" />
                                                    <Setter Property="Foreground" Value="#666666" />
                                                    <Setter Property="BorderBrush" Value="#D0D0D0" />
                                                    <Setter Property="BorderThickness" Value="1" />
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border
                                                                    Background="{TemplateBinding Background}"
                                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                                    CornerRadius="4">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#E0E0E0" />
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter Property="Background" Value="#D0D0D0" />
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <TextBlock Text="−" />
                                        </Button>

                                        <TextBlock
                                            Width="35"
                                            Margin="8,0,8,0"
                                            VerticalAlignment="Center"
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            Text="{Binding Quantity, StringFormat={}{0:F2}}"
                                            TextAlignment="Center" />

                                        <Button
                                            x:Name="BtnAumentar"
                                            Width="28"
                                            Height="28"
                                            Padding="0"
                                            Click="BtnAumentar_Click"
                                            Cursor="Hand"
                                            FontSize="16"
                                            FontWeight="Bold"
                                            Tag="{Binding}">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Background" Value="#F5F5F5" />
                                                    <Setter Property="Foreground" Value="#666666" />
                                                    <Setter Property="BorderBrush" Value="#D0D0D0" />
                                                    <Setter Property="BorderThickness" Value="1" />
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border
                                                                    Background="{TemplateBinding Background}"
                                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                                    CornerRadius="4">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#E0E0E0" />
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter Property="Background" Value="#D0D0D0" />
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <TextBlock Text="+" />
                                        </Button>
                                    </StackPanel>

                                    <!--  Preço Total  -->
                                    <StackPanel
                                        Grid.Column="3"
                                        Margin="15,0,10,0"
                                        VerticalAlignment="Center">
                                        <TextBlock
                                            FontSize="15"
                                            FontWeight="Bold"
                                            Foreground="#1A4D99">
                                            <Run Text="R$ " />
                                            <Run Text="{Binding Total, Mode=OneWay, StringFormat={}{0:F2}}" />
                                        </TextBlock>
                                    </StackPanel>

                                    <!--  Botão Remover  -->
                                    <Button
                                        Grid.Column="4"
                                        Width="28"
                                        Height="28"
                                        Padding="0"
                                        VerticalAlignment="Center"
                                        Click="BtnRemover_Click"
                                        Cursor="Hand"
                                        FontSize="16"
                                        Tag="{Binding}"
                                        ToolTip="Remover produto">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Setter Property="BorderThickness" Value="0" />
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border
                                                                Background="{TemplateBinding Background}"
                                                                CornerRadius="4">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#FFEBEE" />
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter Property="Background" Value="#FFCDD2" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <TextBlock Text="🗑️" />
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </ScrollViewer>

            <!--  Painel Lateral Direito - Total e Botões  -->
            <Border
                Grid.Column="1"
                Padding="15"
                Background="White"
                BorderBrush="#D0D0D0"
                BorderThickness="1"
                CornerRadius="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!--  Informações de Total  -->
                    <StackPanel Grid.Row="0">
                        <TextBlock
                            Margin="0,0,0,8"
                            HorizontalAlignment="Center"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="#333333"
                            Text="TOTAL A PAGAR" />

                        <TextBlock
                            x:Name="TxtTotal"
                            Margin="0,0,0,15"
                            HorizontalAlignment="Center"
                            FontSize="36"
                            FontWeight="Bold"
                            Foreground="#1A4D99"
                            Text="R$ 0,00" />

                        <Border
                            Padding="0,12,0,0"
                            BorderBrush="#E0E0E0"
                            BorderThickness="0,1,0,0">
                            <StackPanel>
                                <Grid Margin="0,0,0,5">
                                    <TextBlock
                                        HorizontalAlignment="Left"
                                        FontSize="11"
                                        Foreground="#666666"
                                        Text="Subtotal:" />
                                    <TextBlock
                                        x:Name="TxtSubtotal"
                                        HorizontalAlignment="Right"
                                        FontSize="11"
                                        FontWeight="SemiBold"
                                        Text="R$ 0,00" />
                                </Grid>

                                <Grid>
                                    <TextBlock
                                        HorizontalAlignment="Left"
                                        FontSize="11"
                                        Foreground="#666666"
                                        Text="Desconto:" />
                                    <TextBlock
                                        x:Name="TxtDesconto"
                                        HorizontalAlignment="Right"
                                        FontSize="11"
                                        FontWeight="SemiBold"
                                        Text="R$ 0,00" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!--  Espaço vazio no meio  -->
                    <Border Grid.Row="1" />

                    <!--  Botões de Ação  -->
                    <StackPanel Grid.Row="2" VerticalAlignment="Bottom">
                        <Button
                            Height="38"
                            BorderThickness="0"
                            Click="Button_Click"
                            Content="✓ FINALIZAR VENDA"
                            Cursor="Hand"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="White">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#1A4D99" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="5">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#153D7A" />
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="Background" Value="#0F2D5C" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button
                            Height="38"
                            Margin="0,8,0,0"
                            BorderThickness="0"
                            Click="Button_Click_2"
                            Content="✕ CANCELAR VENDA"
                            Cursor="Hand"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="White">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#C12E2E" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="5">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#A12424" />
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="Background" Value="#7D1B1B" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</UserControl>
