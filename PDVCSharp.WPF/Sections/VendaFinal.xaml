<UserControl
    x:Class="PDVCSharp.WPF.Sections.VendaFinal"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:PDVCSharp.WPF.Sections"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="#E0E0E0"
    mc:Ignorable="d">
    <DockPanel>
        <Border
            Height="30"
            Background="#444444"
            DockPanel.Dock="Top">
            <Grid>
                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="12"
                    Foreground="White"
                    Text="CAIXA - 01" />
                <StackPanel
                    Margin="0,0,10,0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <TextBlock
                        Margin="5,0"
                        FontSize="10"
                        Foreground="White"
                        Text="📶" />
                    <TextBlock
                        x:Name="TxtHora"
                        FontSize="10"
                        Foreground="White"
                        Text="14:03" />
                </StackPanel>
            </Grid>
        </Border>

        <Border
            Padding="20,10"
            Background="White"
            DockPanel.Dock="Top">
            <StackPanel Orientation="Horizontal">
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="28"
                    Foreground="#2151A1"
                    Text="🛒" />
                <TextBlock
                    Margin="10,0,0,0"
                    VerticalAlignment="Center"
                    FontSize="28"
                    FontWeight="Bold"
                    Foreground="#2151A1"
                    Text="SUPERMARKET" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="22"
                    Foreground="#333333"
                    Text=" –  Finalizar venda" />
            </StackPanel>
        </Border>

        <Grid Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">

                <Border
                    Margin="0,0,0,10"
                    BorderBrush="#2151A1"
                    BorderThickness="1">
                    <StackPanel>
                        <Border Padding="8,4" Background="#2151A1">
                            <TextBlock
                                FontSize="13"
                                FontWeight="Bold"
                                Foreground="White"
                                Text="CLIENTE" />
                        </Border>
                        <StackPanel Margin="8" Orientation="Horizontal">
                            <TextBox
                                x:Name="TxtClienteId"
                                Width="60"
                                Height="28"
                                Margin="0,0,5,0"
                                VerticalContentAlignment="Center"
                                FontSize="14"
                                Text="1" />
                            <Button
                                Width="35"
                                Height="28"
                                Margin="0,0,10,0"
                                Background="#E0E0E0"
                                Content="F2"
                                FontSize="11"
                                FontWeight="Bold" />
                            <ComboBox
                                x:Name="CmbCliente"
                                Height="28"
                                MinWidth="250"
                                HorizontalAlignment="Stretch"
                                VerticalContentAlignment="Center"
                                FontSize="13"
                                SelectionChanged="CmbCliente_SelectionChanged">
                                <ComboBoxItem Content="CONSUMIDOR PADRÃO" IsSelected="True" />
                                <ComboBoxItem Content="VIP" />
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Grid.Column="0"
                        BorderBrush="#8B1A1A"
                        BorderThickness="1">
                        <StackPanel>
                            <Border Padding="8,4" Background="#8B1A1A">
                                <TextBlock
                                    FontSize="13"
                                    FontWeight="Bold"
                                    Foreground="White"
                                    Text="DESCONTO" />
                            </Border>
                            <StackPanel
                                VerticalAlignment="Center"
                                Background="#E0E0E0"
                                Orientation="Horizontal">
                                <TextBlock
                                    Margin="10,0,5,0"
                                    VerticalAlignment="Center"
                                    FontSize="16"
                                    FontWeight="Bold"
                                    Text="R$" />
                                <TextBox
                                    x:Name="TxtDesconto"
                                    Height="35"
                                    HorizontalContentAlignment="Right"
                                    VerticalContentAlignment="Center"
                                    Background="#E0E0E0"
                                    BorderThickness="0"
                                    FontSize="16"
                                    PreviewKeyDown="ValorTextBox_PreviewKeyDown"
                                    PreviewTextInput="ValorTextBox_PreviewTextInput"
                                    Text="0,00" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border
                        Grid.Column="2"
                        BorderBrush="#8B1A1A"
                        BorderThickness="1">
                        <StackPanel>
                            <Border Padding="8,4" Background="#8B1A1A">
                                <TextBlock
                                    FontSize="13"
                                    FontWeight="Bold"
                                    Foreground="White"
                                    Text="FORMA DE PAGAMENTO" />
                            </Border>
                            <ComboBox
                                x:Name="CmbFormaPagamento"
                                Height="35"
                                Margin="5"
                                VerticalContentAlignment="Center"
                                FontSize="14">
                                <ComboBoxItem Content="CAIXA" IsSelected="True" />
                                <ComboBoxItem Content="CARTÃO DE CRÉDITO" />
                                <ComboBoxItem Content="CARTÃO DE DÉBITO" />
                                <ComboBoxItem Content="DINHEIRO" />
                                <ComboBoxItem Content="CHEQUE" />
                            </ComboBox>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Margin="0,0,0,10">
                    <StackPanel>
                        <Border Padding="8,4" Background="#1B2A4A">
                            <TextBlock
                                FontSize="13"
                                FontWeight="Bold"
                                Foreground="White"
                                Text="TOTAL" />
                        </Border>
                        <Border Padding="5" Background="White">
                            <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                <TextBlock
                                    Margin="5,0,5,0"
                                    VerticalAlignment="Center"
                                    FontSize="24"
                                    FontWeight="Bold"
                                    Text="R$" />
                                <TextBlock
                                    x:Name="TxtTotal"
                                    VerticalAlignment="Center"
                                    FontSize="24"
                                    FontWeight="Bold"
                                    Text="0,00" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Grid Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>


                </Grid>

                <Grid Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>


                </Grid>

                <Border>
                    <StackPanel>
                        <Border Padding="8,4" Background="#1B2A4A">
                            <TextBlock
                                FontSize="13"
                                FontWeight="Bold"
                                Foreground="White"
                                Text="SALDO" />
                        </Border>
                        <Border Padding="5" Background="White">
                            <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                <TextBlock
                                    Margin="5,0,5,0"
                                    VerticalAlignment="Center"
                                    FontSize="24"
                                    FontWeight="Bold"
                                    Text="R$" />
                                <TextBlock
                                    x:Name="TxtSaldo"
                                    VerticalAlignment="Center"
                                    FontSize="24"
                                    FontWeight="Bold"
                                    Text="0,00" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <Button
                    x:Name="BtnAdicionarPagamento"
                    Height="40"
                    Margin="0,0,0,10"
                    Background="#2151A1"
                    BorderThickness="0"
                    Click="BtnAdicionarPagamento_Click"
                    Content="Adicionar pagamento"
                    Cursor="Hand"
                    FontSize="14"
                    FontWeight="Bold"
                    Foreground="White" />

                <DataGrid
                    x:Name="DgCartoes"
                    Height="200"
                    Margin="0,0,0,15"
                    x:FieldModifier="public"
                    AutoGenerateColumns="False"
                    Background="White"
                    BorderBrush="#2151A1"
                    BorderThickness="1"
                    CanUserAddRows="False"
                    GridLinesVisibility="Horizontal"
                    HeadersVisibility="Column"
                    IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn
                            Width="*"
                            Binding="{Binding Cartao}"
                            Header="Cartão" />
                        <DataGridTextColumn
                            Width="70"
                            Binding="{Binding Parcela}"
                            Header="Parcela" />
                        <DataGridTextColumn
                            Width="80"
                            Binding="{Binding Valor}"
                            Header="Valor" />
                    </DataGrid.Columns>
                </DataGrid>

                <Border Margin="0,0,0,15">
                    <StackPanel>
                        <Border Padding="10,6" Background="#1B2A4A">
                            <TextBlock
                                FontSize="18"
                                FontStyle="Italic"
                                FontWeight="Bold"
                                Foreground="White"
                                Text="SUBTOTAL" />
                        </Border>
                        <Border Padding="10" Background="White">
                            <TextBlock
                                x:Name="TxtSubtotal"
                                HorizontalAlignment="Right"
                                FontSize="48"
                                FontWeight="Bold"
                                Text="0,00" />
                        </Border>
                    </StackPanel>
                </Border>

                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0">
                        <StackPanel>
                            <Border Padding="10,6" Background="#1B2A4A">
                                <TextBlock
                                    FontSize="14"
                                    FontStyle="Italic"
                                    FontWeight="Bold"
                                    Foreground="White"
                                    Text="TOTAL RECEBIDO" />
                            </Border>
                            <Border Padding="10" Background="White">
                                <TextBox
                                    x:Name="TxtTotalRecebido"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Right"
                                    VerticalContentAlignment="Center"
                                    BorderThickness="0"
                                    FontSize="28"
                                    FontWeight="Bold"
                                    PreviewKeyDown="ValorTextBox_PreviewKeyDown"
                                    PreviewTextInput="ValorTextBox_PreviewTextInput"
                                    Text="0,00"
                                    TextChanged="TxtTotalRecebido_TextChanged" />
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2">
                        <StackPanel>
                            <Border Padding="10,6" Background="#1B2A4A">
                                <TextBlock
                                    FontSize="14"
                                    Foreground="White"
                                    Text=" " />
                            </Border>
                            <Border Padding="10" Background="White">
                                <TextBlock
                                    x:Name="TxtTroco"
                                    HorizontalAlignment="Right"
                                    FontSize="28"
                                    FontWeight="Bold"
                                    Text="0,00" />
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>

                <Button
                    x:Name="BtnFinalizar"
                    Height="60"
                    Background="#1A7A7A"
                    BorderThickness="0"
                    Click="BtnFinalizar_Click"
                    Content="Finalizar"
                    Cursor="Hand"
                    FontSize="24"
                    FontWeight="Bold"
                    Foreground="White">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>
    </DockPanel>
</UserControl>