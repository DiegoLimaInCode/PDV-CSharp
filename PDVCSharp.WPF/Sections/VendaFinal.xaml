<Window x:Class="PDVCSharp.WPF.Sections.VendaFinal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PDVCSharp.WPF.Sections"
        mc:Ignorable="d"
        Title="VendaFinal"
        Height="720"
        Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="#E0E0E0">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#444444" Height="30">
            <Grid>
                <TextBlock Text="CAIXA - 01"
                           Foreground="White"
                           FontSize="12"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center" />
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,10,0">
                    <TextBlock Text="📶" Foreground="White" FontSize="10" Margin="5,0" />
                    <TextBlock x:Name="TxtHora"
                               Text="14:03"
                               Foreground="White"
                               FontSize="10" />
                </StackPanel>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Top" Background="White" Padding="20,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🛒" FontSize="28" Foreground="#2151A1" VerticalAlignment="Center" />
                <TextBlock Text="SUPERMARKET"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#2151A1"
                           VerticalAlignment="Center"
                           Margin="10,0,0,0" />
                <TextBlock Text=" –  Finalizar venda"
                           FontSize="22"
                           Foreground="#333333"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <Grid Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">

                <Border BorderBrush="#2151A1" BorderThickness="1" Margin="0,0,0,10">
                    <StackPanel>
                        <Border Background="#2151A1" Padding="8,4">
                            <TextBlock Text="CLIENTE" Foreground="White" FontWeight="Bold" FontSize="13" />
                        </Border>
                        <StackPanel Orientation="Horizontal" Margin="8">
                            <TextBox x:Name="TxtClienteId" Text="1" Width="60" Height="28"
                                     FontSize="14" VerticalContentAlignment="Center" Margin="0,0,5,0" />
                            <Button Content="F2" Width="35" Height="28" FontSize="11" FontWeight="Bold"
                                    Background="#E0E0E0" Margin="0,0,10,0" />
                            <ComboBox x:Name="CmbCliente" Height="28" FontSize="13"
                                      VerticalContentAlignment="Center" HorizontalAlignment="Stretch"
                                      MinWidth="250">
                                <ComboBoxItem Content="CONSUMIDOR PADRÃO" IsSelected="True" />
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" BorderBrush="#8B1A1A" BorderThickness="1">
                        <StackPanel>
                            <Border Background="#8B1A1A" Padding="8,4">
                                <TextBlock Text="DESCONTO" Foreground="White" FontWeight="Bold" FontSize="13" />
                            </Border>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Background="#E0E0E0">
                                <TextBlock Text="R$" FontSize="16" FontWeight="Bold"
                                           VerticalAlignment="Center" Margin="10,0,5,0" />
                                <TextBox x:Name="TxtDesconto" Text="0,00" FontSize="16"
                                         HorizontalContentAlignment="Right" VerticalContentAlignment="Center"
                                         Height="35" BorderThickness="0" Background="#E0E0E0"
                                         PreviewTextInput="ValorTextBox_PreviewTextInput"
                                         PreviewKeyDown="ValorTextBox_PreviewKeyDown" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" BorderBrush="#8B1A1A" BorderThickness="1">
                        <StackPanel>
                            <Border Background="#8B1A1A" Padding="8,4">
                                <TextBlock Text="FORMA DE PAGAMENTO" Foreground="White" FontWeight="Bold" FontSize="13" />
                            </Border>
                            <ComboBox x:Name="CmbFormaPagamento" Height="35" FontSize="14"
                                      VerticalContentAlignment="Center" Margin="5">
                                <ComboBoxItem Content="CAIXA" IsSelected="True" />
                                <ComboBoxItem Content="CARTÃO DE CRÉDITO" />
                                <ComboBoxItem Content="CARTÃO DE DÉBITO" />
                                <ComboBoxItem Content="DINHEIRO" />
                                <ComboBoxItem Content="CHEQUE" />
                            </ComboBox>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Margin="0,0,0,10">
                    <StackPanel>
                        <Border Background="#1B2A4A" Padding="8,4">
                            <TextBlock Text="TOTAL" Foreground="White" FontWeight="Bold" FontSize="13" />
                        </Border>
                        <Border Background="White" Padding="5">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="R$" FontSize="24" FontWeight="Bold"
                                           VerticalAlignment="Center" Margin="5,0,5,0" />
                                <TextBox x:Name="TxtTotal" Text="0,00" FontSize="24" FontWeight="Bold"
                                         VerticalContentAlignment="Center" HorizontalContentAlignment="Right"
                                         HorizontalAlignment="Stretch" Height="35" BorderThickness="0"
                                         PreviewTextInput="ValorTextBox_PreviewTextInput"
                                         PreviewKeyDown="ValorTextBox_PreviewKeyDown" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0">
                        <StackPanel>
                            <Border Background="#8B1A1A" Padding="8,4">
                                <TextBlock Text="DINHEIRO" Foreground="White" FontWeight="Bold" FontSize="13" />
                            </Border>
                            <Border Background="White" Padding="5">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="R$" FontSize="22" FontWeight="Bold"
                                               VerticalAlignment="Center" Margin="5,0,5,0" />
                                    <TextBox x:Name="TxtDinheiro" Text="0,00" FontSize="22" FontWeight="Bold"
                                             HorizontalContentAlignment="Right" VerticalContentAlignment="Center"
                                             Height="35" BorderThickness="0"
                                             PreviewTextInput="ValorTextBox_PreviewTextInput"
                                             PreviewKeyDown="ValorTextBox_PreviewKeyDown" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2">
                        <StackPanel>
                            <Border Background="#8B1A1A" Padding="8,4">
                                <TextBlock Text="CHEQUE" Foreground="White" FontWeight="Bold" FontSize="13" />
                            </Border>
                            <Border Background="White" Padding="5">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="R$" FontSize="22" FontWeight="Bold"
                                               VerticalAlignment="Center" Margin="5,0,5,0" />
                                    <TextBox x:Name="TxtCheque" Text="0,00" FontSize="22" FontWeight="Bold"
                                             HorizontalContentAlignment="Right" VerticalContentAlignment="Center"
                                             Height="35" BorderThickness="0"
                                             PreviewTextInput="ValorTextBox_PreviewTextInput"
                                             PreviewKeyDown="ValorTextBox_PreviewKeyDown" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0">
                        <StackPanel>
                            <Border Background="#8B1A1A" Padding="8,4">
                                <TextBlock Text="CARTÃO DE CRÉDITO" Foreground="White" FontWeight="Bold" FontSize="13" />
                            </Border>
                            <Border Background="White" Padding="5">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="R$" FontSize="22" FontWeight="Bold"
                                               VerticalAlignment="Center" Margin="5,0,5,0" />
                                    <TextBox x:Name="TxtCartaoCredito" Text="0,00" FontSize="22" FontWeight="Bold"
                                             HorizontalContentAlignment="Right" VerticalContentAlignment="Center"
                                             Height="35" BorderThickness="0"
                                             PreviewTextInput="ValorTextBox_PreviewTextInput"
                                             PreviewKeyDown="ValorTextBox_PreviewKeyDown" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2">
                        <StackPanel>
                            <Border Background="#8B1A1A" Padding="8,4">
                                <TextBlock Text="CARTÃO DE DÉBITO" Foreground="White" FontWeight="Bold" FontSize="13" />
                            </Border>
                            <Border Background="White" Padding="5">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="R$" FontSize="22" FontWeight="Bold"
                                               VerticalAlignment="Center" Margin="5,0,5,0" />
                                    <TextBox x:Name="TxtCartaoDebito" Text="0,00" FontSize="22" FontWeight="Bold"
                                             HorizontalContentAlignment="Right" VerticalContentAlignment="Center"
                                             Height="35" BorderThickness="0"
                                             PreviewTextInput="ValorTextBox_PreviewTextInput"
                                             PreviewKeyDown="ValorTextBox_PreviewKeyDown" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border>
                    <StackPanel>
                        <Border Background="#1B2A4A" Padding="8,4">
                            <TextBlock Text="SALDO" Foreground="White" FontWeight="Bold" FontSize="13" />
                        </Border>
                        <Border Background="White" Padding="5">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="R$" FontSize="24" FontWeight="Bold"
                                           VerticalAlignment="Center" Margin="5,0,5,0" />
                                <TextBlock x:Name="TxtSaldo" Text="0,00" FontSize="24"
                                           FontWeight="Bold" VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="2">

                <DataGrid x:Name="DgCartoes"
                          AutoGenerateColumns="False"
                          Height="200"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          BorderBrush="#2151A1"
                          BorderThickness="1"
                          CanUserAddRows="False"
                          Background="White"
                          Margin="0,0,0,15">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Cartão" Width="*" Binding="{Binding Cartao}" />
                        <DataGridTextColumn Header="Parcela" Width="70" Binding="{Binding Parcela}" />
                        <DataGridTextColumn Header="NSU" Width="80" Binding="{Binding NSU}" />
                        <DataGridTextColumn Header="Autorização" Width="100" Binding="{Binding Autorizacao}" />
                        <DataGridTextColumn Header="Valor" Width="80" Binding="{Binding Valor}" />
                    </DataGrid.Columns>
                </DataGrid>

                <Border Margin="0,0,0,15">
                    <StackPanel>
                        <Border Background="#1B2A4A" Padding="10,6">
                            <TextBlock Text="SUBTOTAL" Foreground="White" FontWeight="Bold"
                                       FontSize="18" FontStyle="Italic" />
                        </Border>
                        <Border Background="White" Padding="10">
                            <TextBlock x:Name="TxtSubtotal" Text="0,00" FontSize="48"
                                       FontWeight="Bold" HorizontalAlignment="Right" />
                        </Border>
                    </StackPanel>
                </Border>

                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0">
                        <StackPanel>
                            <Border Background="#1B2A4A" Padding="10,6">
                                <TextBlock Text="TOTAL RECEBIDO" Foreground="White"
                                           FontWeight="Bold" FontSize="14" FontStyle="Italic" />
                            </Border>
                            <Border Background="White" Padding="10">
                                <TextBlock x:Name="TxtTotalRecebido" Text="0,00"
                                           FontSize="28" FontWeight="Bold" HorizontalAlignment="Right" />
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2">
                        <StackPanel>
                            <Border Background="#1B2A4A" Padding="10,6">
                                <TextBlock Text=" " Foreground="White" FontSize="14" />
                            </Border>
                            <Border Background="White" Padding="10">
                                <TextBlock x:Name="TxtTroco" Text="0,00"
                                           FontSize="28" FontWeight="Bold" HorizontalAlignment="Right" />
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>

                <Button x:Name="BtnFinalizar"
                        Content="Finalizar"
                        Height="60"
                        FontSize="24"
                        FontWeight="Bold"
                        Foreground="White"
                        Background="#1A7A7A"
                        BorderThickness="0"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="8"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>
