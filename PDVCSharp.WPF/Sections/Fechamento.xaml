<Window
    x:Class="PDVCSharp.WPF.Sections.Fechamento"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:PDVCSharp.WPF.Sections"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:PDVCSharp.WPF.ViewModels"
    Title="Fechamento"
    Width="800"
    Height="450"
    mc:Ignorable="d">
    <Window.DataContext>
        <vm:FechamentoViewModel />
    </Window.DataContext>
    <Grid Background="#888888">
        <Border Background="#F8F4F4" ClipToBounds="True" />

        <DockPanel>
            <Border
                Height="30"
                Background="#444444"
                DockPanel.Dock="Top">
                <Grid>
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="White"
                        Text="CAIXA - 01 " />

                    <StackPanel
                        Margin="0,0,10,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <TextBlock
                            Margin="5,0"
                            FontSize="10"
                            Foreground="White"
                            Text="📶" />
                        <TextBlock
                            x:Name="TxtHora"
                            FontSize="10"
                            Foreground="White"
                            Text="{Binding Now, Mode=OneWay, StringFormat={}{0:HH:mm}}" />
                    </StackPanel>
                </Grid>
            </Border>
            <Grid>
                <StackPanel
                    Margin="30"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Orientation="Horizontal">
                    <TextBlock
                        FontSize="24"
                        Foreground="#2151A1"
                        Text="🛒" />
                    <TextBlock
                        Margin="10,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="20"
                        FontWeight="Bold"
                        Foreground="#2151A1"
                        Text="SUPERMARKET" />
                </StackPanel>
                <StackPanel
                    Width="400"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                    <TextBlock
                        Margin="0,0,0,30"
                        FontSize="40"
                        FontWeight="Bold"
                        Foreground="#333"
                        Text="Fechamento do Caixa"
                        TextAlignment="Center" />
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            HorizontalAlignment="Center"
                            FontSize="14"
                            Foreground="#666">
                            <Run Text="Operador: " />
                            <Run FontWeight="SemiBold" Text="{Binding OperatorName, Mode=OneWay}" />
                        </TextBlock>

                        <TextBlock
                            Grid.Column="1"
                            HorizontalAlignment="Center"
                            FontSize="14"
                            Foreground="#666">
                            <Run Text="Data: " />
                            <Run FontWeight="SemiBold" Text="{Binding Today, Mode=OneWay, StringFormat={}{0:dd/MM/yyyy}}" />
                        </TextBlock>

                    </Grid>
                    <Border Background="White" CornerRadius="20">
                        <Border.Effect>
                            <DropShadowEffect
                                BlurRadius="15"
                                Opacity="0.4"
                                ShadowDepth="5"
                                Color="#000000" />
                        </Border.Effect>
                        <Grid Margin="10,10,10,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="80" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!--  Total de Vendas  -->
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="0"
                                FontWeight="Bold"
                                Text="Total de Vendas :" />
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="1"
                                Margin="5,0,0,0"
                                Text="R$"
                                TextAlignment="Right" />
                            <TextBox
                                Grid.Row="0"
                                Grid.Column="2"
                                BorderThickness="0"
                                Text="1.250,00"
                                TextAlignment="Right" />

                            <!--  Linha divisória  -->
                            <Border
                                Grid.Row="1"
                                Grid.ColumnSpan="3"
                                Height="1"
                                Margin="0,10,0,10"
                                Background="Gray" />

                            <!--  Título: Vendas por Forma de Pagamento  -->
                            <TextBlock
                                Grid.Row="2"
                                Grid.Column="0"
                                FontSize="12"
                                FontWeight="Bold"
                                Text="Vendas por Forma de Pagamento" />

                            <!--  Dinheiro  -->
                            <TextBlock
                                Grid.Row="3"
                                Grid.Column="0"
                                Text="Dinheiro :" />
                            <TextBlock
                                Grid.Row="3"
                                Grid.Column="1"
                                Margin="5,0,0,0"
                                Text="R$"
                                TextAlignment="Right" />
                            <TextBox
                                Grid.Row="3"
                                Grid.Column="2"
                                BorderThickness="0"
                                Text="450,00"
                                TextAlignment="Right" />

                            <!--  Cartão de Crédito  -->
                            <TextBlock
                                Grid.Row="4"
                                Grid.Column="0"
                                Text="Cartão de Crédito :" />
                            <TextBlock
                                Grid.Row="4"
                                Grid.Column="1"
                                Margin="5,0,0,0"
                                Text="R$"
                                TextAlignment="Right" />
                            <TextBox
                                Grid.Row="4"
                                Grid.Column="2"
                                BorderThickness="0"
                                Text="600,00"
                                TextAlignment="Right" />

                            <!--  Cartão de Débito  -->
                            <TextBlock
                                Grid.Row="5"
                                Grid.Column="0"
                                Text="Cartão de Débito :" />
                            <TextBlock
                                Grid.Row="5"
                                Grid.Column="1"
                                Margin="5,0,0,0"
                                Text="R$"
                                TextAlignment="Right" />
                            <TextBox
                                Grid.Row="5"
                                Grid.Column="2"
                                BorderThickness="0"
                                Text="200,00"
                                TextAlignment="Right" />

                            <!--  Pix  -->
                            <TextBlock
                                Grid.Row="6"
                                Grid.Column="0"
                                Text="Pix :" />
                            <TextBlock
                                Grid.Row="6"
                                Grid.Column="1"
                                Margin="5,0,0,0"
                                Text="R$"
                                TextAlignment="Right" />
                            <TextBox
                                Grid.Row="6"
                                Grid.Column="2"
                                BorderThickness="0"
                                Text="100,00"
                                TextAlignment="Right" />

                            <!--  Voucher  -->
                            <TextBlock
                                Grid.Row="7"
                                Grid.Column="0"
                                Text="Voucher :" />
                            <TextBlock
                                Grid.Row="7"
                                Grid.Column="1"
                                Margin="5,0,0,0"
                                Text="R$"
                                TextAlignment="Right" />
                            <TextBox
                                Grid.Row="7"
                                Grid.Column="2"
                                BorderThickness="0"
                                Text="50,00"
                                TextAlignment="Right" />

                            <!--  Linha divisória  -->
                            <Border
                                Grid.Row="8"
                                Grid.ColumnSpan="3"
                                Height="1"
                                Margin="0,10,0,10"
                                Background="Gray" />

                            <!--  Título: Resumo Financeiro  -->
                            <TextBlock
                                Grid.Row="9"
                                Grid.Column="0"
                                FontSize="12"
                                FontWeight="Bold"
                                Text="Resumo Financeiro" />

                            <!--  Suprimentos  -->
                            <TextBlock
                                Grid.Row="10"
                                Grid.Column="0"
                                Text="Suprimentos :" />
                            <TextBlock
                                Grid.Row="10"
                                Grid.Column="1"
                                Margin="5,0,0,0"
                                Text="R$"
                                TextAlignment="Right" />
                            <TextBox
                                Grid.Row="10"
                                Grid.Column="2"
                                BorderThickness="0"
                                Text="0,00"
                                TextAlignment="Right" />

                            <!--  Sangrias  -->
                            <TextBlock
                                Grid.Row="11"
                                Grid.Column="0"
                                Text="Sangrias :" />
                            <TextBlock
                                Grid.Row="11"
                                Grid.Column="1"
                                Margin="5,0,0,0"
                                Text="R$"
                                TextAlignment="Right" />
                            <TextBox
                                Grid.Row="11"
                                Grid.Column="2"
                                BorderThickness="0"
                                Text="-300,00"
                                TextAlignment="Right" />

                            <!--  Total em Caixa  -->
                            <TextBlock
                                Grid.Row="12"
                                Grid.Column="0"
                                FontWeight="Bold"
                                Text="Total em Caixa (Dinheiro) :" />
                            <TextBlock
                                Grid.Row="12"
                                Grid.Column="1"
                                Margin="5,0,0,0"
                                FontWeight="Bold"
                                Text="R$"
                                TextAlignment="Right" />
                            <TextBox
                                Grid.Row="12"
                                Grid.Column="2"
                                BorderThickness="0"
                                FontWeight="Bold"
                                Text="150,00"
                                TextAlignment="Right" />

                            <!--  Botão Fechar Caixa  -->
                            <Border
                                Grid.Row="13"
                                Grid.ColumnSpan="3"
                                Margin="0,15,0,0"
                                Background="#D32F2F"
                                ClipToBounds="True"
                                CornerRadius="20">
                                <Button
                                    Height="40"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Content="🔒 FECHAR CAIXA"
                                    FontSize="14"
                                    FontWeight="Bold"
                                    Foreground="White" />
                            </Border>

                        </Grid>
                    </Border>
                </StackPanel>

            </Grid>
        </DockPanel>
    </Grid>
</Window>
