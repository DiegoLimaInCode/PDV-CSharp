<Window x:Class="PDVCSharp.WPF.Sections.Fechamento"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PDVCSharp.WPF.Sections"
        xmlns:vm="clr-namespace:PDVCSharp.WPF.ViewModels"
        mc:Ignorable="d"
        Title="Fechamento" Height="450" Width="800">
    <Window.DataContext>
        <vm:FechamentoViewModel />
    </Window.DataContext>
    <Grid Background="#888888">
        <Border Background="#F8F4F4" ClipToBounds="True"/>

        <DockPanel>
            <Border DockPanel.Dock="Top" Background="#444444" Height="30">
                <Grid>
                    <TextBlock Text="CAIXA - 01 " Foreground="White"
               FontSize="12" VerticalAlignment="Center"
               HorizontalAlignment="Center"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0">
                        <TextBlock Text="📶" Foreground="White" FontSize="10" Margin="5,0" />
                        <TextBlock x:Name="TxtHora" Text="{Binding Now, Mode=OneWay, StringFormat={}{0:HH:mm}}" Foreground="White" FontSize="10"/>
                    </StackPanel>
                </Grid>
            </Border>
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="30">
                    <TextBlock Text="🛒" FontSize="24" Foreground="#2151A1"/>
                    <TextBlock Text="SUPERMARKET" FontSize="20" FontWeight="Bold"
               Foreground="#2151A1" VerticalAlignment="Center" Margin="10,0,0,0" />
                </StackPanel>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="400">
                    <TextBlock Text="Fechamento do Caixa" FontSize="40" FontWeight="Bold" Margin="0,0,0,30" Foreground="#333" TextAlignment="Center"/>
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" HorizontalAlignment="Center" Foreground="#666" FontSize="14">
                            <Run Text="Operador: " />
                            <Run Text="{Binding OperatorName, Mode=OneWay}" FontWeight="SemiBold" />
                        </TextBlock>

                        <TextBlock Grid.Column="1" HorizontalAlignment="Center" Foreground="#666" FontSize="14">
                            <Run Text="Data: " />
                            <Run Text="{Binding Today, Mode=OneWay, StringFormat={}{0:dd/MM/yyyy}}" FontWeight="SemiBold" />
                        </TextBlock>

                    </Grid>
                    <Border CornerRadius="20" Background="White">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="15" ShadowDepth="5" Opacity="0.4" Color="#000000" />
                        </Border.Effect>
                        <Grid Margin="10,10,10,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="80" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Total de Vendas -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Total de Vendas :" FontWeight="Bold" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="R$" TextAlignment="Right" Margin="5,0,0,0" />
                            <TextBox Grid.Row="0" Grid.Column="2" BorderThickness="0" Text="1.250,00" TextAlignment="Right" />

                            <!-- Linha divisória -->
                            <Border Grid.Row="1" Grid.ColumnSpan="3" Height="1" Background="Gray" Margin="0,10,0,10" />

                            <!-- Título: Vendas por Forma de Pagamento -->
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Vendas por Forma de Pagamento" FontWeight="Bold" FontSize="12" />

                            <!-- Dinheiro -->
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Dinheiro :" />
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="R$" TextAlignment="Right" Margin="5,0,0,0" />
                            <TextBox Grid.Row="3" Grid.Column="2" BorderThickness="0" Text="450,00" TextAlignment="Right" />

                            <!-- Cartão de Crédito -->
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Cartão de Crédito :" />
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="R$" TextAlignment="Right" Margin="5,0,0,0" />
                            <TextBox Grid.Row="4" Grid.Column="2" BorderThickness="0" Text="600,00" TextAlignment="Right" />

                            <!-- Cartão de Débito -->
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Cartão de Débito :" />
                            <TextBlock Grid.Row="5" Grid.Column="1" Text="R$" TextAlignment="Right" Margin="5,0,0,0" />
                            <TextBox Grid.Row="5" Grid.Column="2" BorderThickness="0" Text="200,00" TextAlignment="Right" />

                            <!-- Pix -->
                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Pix :" />
                            <TextBlock Grid.Row="6" Grid.Column="1" Text="R$" TextAlignment="Right" Margin="5,0,0,0" />
                            <TextBox Grid.Row="6" Grid.Column="2" BorderThickness="0" Text="100,00" TextAlignment="Right" />

                            <!-- Voucher -->
                            <TextBlock Grid.Row="7" Grid.Column="0" Text="Voucher :" />
                            <TextBlock Grid.Row="7" Grid.Column="1" Text="R$" TextAlignment="Right" Margin="5,0,0,0" />
                            <TextBox Grid.Row="7" Grid.Column="2" BorderThickness="0" Text="50,00" TextAlignment="Right" />

                            <!-- Linha divisória -->
                            <Border Grid.Row="8" Grid.ColumnSpan="3" Height="1" Background="Gray" Margin="0,10,0,10" />

                            <!-- Título: Resumo Financeiro -->
                            <TextBlock Grid.Row="9" Grid.Column="0" Text="Resumo Financeiro" FontWeight="Bold" FontSize="12" />

                            <!-- Suprimentos -->
                            <TextBlock Grid.Row="10" Grid.Column="0" Text="Suprimentos :" />
                            <TextBlock Grid.Row="10" Grid.Column="1" Text="R$" TextAlignment="Right" Margin="5,0,0,0" />
                            <TextBox Grid.Row="10" Grid.Column="2" BorderThickness="0" Text="0,00" TextAlignment="Right" />

                            <!-- Sangrias -->
                            <TextBlock Grid.Row="11" Grid.Column="0" Text="Sangrias :" />
                            <TextBlock Grid.Row="11" Grid.Column="1" Text="R$" TextAlignment="Right" Margin="5,0,0,0" />
                            <TextBox Grid.Row="11" Grid.Column="2" BorderThickness="0" Text="-300,00" TextAlignment="Right" />

                            <!-- Total em Caixa -->
                            <TextBlock Grid.Row="12" Grid.Column="0" Text="Total em Caixa (Dinheiro) :" FontWeight="Bold" />
                            <TextBlock Grid.Row="12" Grid.Column="1" Text="R$" TextAlignment="Right" Margin="5,0,0,0" FontWeight="Bold" />
                            <TextBox Grid.Row="12" Grid.Column="2" BorderThickness="0" Text="150,00" TextAlignment="Right" FontWeight="Bold" />

                            <!-- Botão Fechar Caixa -->
                            <Border Grid.Row="13" Grid.ColumnSpan="3" CornerRadius="20" Margin="0,15,0,0" ClipToBounds="True" Background="#D32F2F">
                                <Button Foreground="White" 
                                        Height="40" FontWeight="Bold" FontSize="14" 
                                        Content="🔒 FECHAR CAIXA" Background="Transparent" BorderThickness="0" />
                            </Border>

                        </Grid>
                    </Border>
                </StackPanel>

            </Grid>
        </DockPanel>
    </Grid>
</Window>
