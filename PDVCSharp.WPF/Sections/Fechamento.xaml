<UserControl
    x:Class="PDVCSharp.WPF.Sections.Fechamento"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:PDVCSharp.WPF.Sections"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:PDVCSharp.WPF.ViewModels"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">


    <Grid Background="#888888">
        <Border Background="#F8F4F4" ClipToBounds="True" />

        <DockPanel>
            <Border
                Height="30"
                Background="#444444"
                DockPanel.Dock="Top">
                <Grid>
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="White"
                        Text="CAIXA - 01 " />

                    <StackPanel
                        Margin="0,0,10,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <TextBlock
                            Margin="5,0"
                            FontSize="10"
                            Foreground="White"
                            Text="📶" />
                        <TextBlock
                            x:Name="TxtHora"
                            FontSize="10"
                            Foreground="White"
                            Text="{Binding Now, Mode=OneWay, StringFormat={}{0:HH:mm}}" />
                    </StackPanel>
                </Grid>
            </Border>
            <Grid>
                <StackPanel
                    Margin="30"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Orientation="Horizontal">
                    <TextBlock
                        FontSize="24"
                        Foreground="#2151A1"
                        Text="🛒" />
                    <TextBlock
                        Margin="10,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="20"
                        FontWeight="Bold"
                        Foreground="#2151A1"
                        Text="SUPERMARKET" />
                </StackPanel>
                <StackPanel
                    Width="460"
                    Margin="20"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                    <TextBlock
                        Margin="0,0,0,26"
                        FontSize="42"
                        FontWeight="Bold"
                        Foreground="#333"
                        Text="Fechamento do Caixa"
                        TextAlignment="Center" />
                    <Grid Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            HorizontalAlignment="Center"
                            FontSize="15"
                            Foreground="#666">
                            <Run Text="Operador: " />
                            <Run FontWeight="SemiBold" Text="{Binding OperatorName, Mode=OneWay}" />
                        </TextBlock>

                        <TextBlock
                            Grid.Column="1"
                            HorizontalAlignment="Center"
                            FontSize="15"
                            Foreground="#666">
                            <Run Text="Data: " />
                            <Run FontWeight="SemiBold" Text="{Binding Today, Mode=OneWay, StringFormat={}{0:dd/MM/yyyy}}" />
                        </TextBlock>

                    </Grid>
                    <Border Background="White" CornerRadius="20" Padding="12">
                        <Border.Effect>
                            <DropShadowEffect
                                BlurRadius="14"
                                Direction="270"
                                Opacity="0.18"
                                ShadowDepth="2"
                                Color="#000000" />
                        </Border.Effect>
                        <Grid Margin="6">
                            <Grid.Resources>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontSize" Value="14" />
                                    <Setter Property="FontWeight" Value="Medium" />
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                </Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Height" Value="26" />
                                    <Setter Property="FontSize" Value="14" />
                                    <Setter Property="FontWeight" Value="Medium" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="VerticalContentAlignment" Value="Center" />
                                    <Setter Property="TextAlignment" Value="Right" />
                                </Style>

                                <Style x:Key="RoundedBlueButton" TargetType="Button">
                                    <Setter Property="Height" Value="44" />
                                    <Setter Property="Background" Value="#2151A1" />
                                    <Setter Property="Foreground" Value="White" />
                                    <Setter Property="FontSize" Value="15" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Cursor" Value="Hand" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border
                                                    x:Name="ButtonBorder"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="20">
                                                    <ContentPresenter
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ButtonBorder" Property="Background" Value="#4E7CC6" />
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="ButtonBorder" Property="Background" Value="#1A3F7D" />
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.6" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>

                                <Style x:Key="RoundedRedButton" TargetType="Button" BasedOn="{StaticResource RoundedBlueButton}">
                                    <Setter Property="Background" Value="#D32F2F" />
                                    <Setter Property="FontWeight" Value="Bold" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border
                                                    x:Name="ButtonBorder"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="20">
                                                    <ContentPresenter
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ButtonBorder" Property="Background" Value="#E06666" />
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="ButtonBorder" Property="Background" Value="#A92626" />
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.6" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Grid.Resources>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="100" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!--  Total de Vendas  -->
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="0"
                                FontWeight="Bold"
                                Text="Total de Vendas :" />
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="1"
                                Margin="5,0,0,0"
                                Text=""
                                TextAlignment="Right" />
                            <TextBox
                                Grid.Row="0"
                                Grid.Column="2"
                                BorderThickness="0"
                                Text="{Binding TotalVendas, Mode=OneWay, StringFormat=R$ {0:N2}}"
                                TextAlignment="Right" />

                            <!--  Linha divisória  -->
                            <Border
                                Grid.Row="1"
                                Grid.ColumnSpan="3"
                                Height="1"
                                Margin="0,10,0,10"
                                Background="Gray" />

                            <!--  Título: Vendas por Forma de Pagamento  -->
                            <TextBlock
                                Grid.Row="2"
                                Grid.Column="0"
                                FontSize="13"
                                FontWeight="Bold"
                                Text="Vendas por Forma de Pagamento" />

                            <!--  Dinheiro  -->
                            <TextBlock
                                Grid.Row="3"
                                Grid.Column="0"
                                Text="Dinheiro :" />
                            <TextBlock
                                Grid.Row="3"
                                Grid.Column="1"
                                Margin="5,0,0,0"
                                Text=""
                                TextAlignment="Right" />
                            <TextBox
                                Grid.Row="3"
                                Grid.Column="2"
                                BorderThickness="0"
                                Text="{Binding TotalDinheiro, Mode=OneWay, StringFormat=R$ {0:N2}}"
                                TextAlignment="Right" />

                            <!--  Cartão de Crédito  -->
                            <TextBlock
                                Grid.Row="4"
                                Grid.Column="0"
                                Text="Cartão de Crédito :" />
                            <TextBlock
                                Grid.Row="4"
                                Grid.Column="1"
                                Margin="5,0,0,0"
                                Text=""
                                TextAlignment="Right" />
                            <TextBox
                                Grid.Row="4"
                                Grid.Column="2"
                                BorderThickness="0"
                                Text="{Binding TotalCartaoCredito, Mode=OneWay, StringFormat=R$ {0:N2}}"
                                TextAlignment="Right" />

                            <!--  Cartão de Débito  -->
                            <TextBlock
                                Grid.Row="5"
                                Grid.Column="0"
                                Text="Cartão de Débito :" />
                            <TextBlock
                                Grid.Row="5"
                                Grid.Column="1"
                                Margin="5,0,0,0"
                                Text=""
                                TextAlignment="Right" />
                            <TextBox
                                Grid.Row="5"
                                Grid.Column="2"
                                BorderThickness="0"
                                Text="{Binding TotalCartaoDebito, Mode=OneWay, StringFormat=R$ {0:N2}}"
                                TextAlignment="Right" />

                            <!--  Pix  -->
                            <TextBlock
                                Grid.Row="6"
                                Grid.Column="0"
                                Text="Pix :" />
                            <TextBlock
                                Grid.Row="6"
                                Grid.Column="1"
                                Margin="5,0,0,0"
                                Text=""
                                TextAlignment="Right" />
                            <TextBox
                                Grid.Row="6"
                                Grid.Column="2"
                                BorderThickness="0"
                                Text="{Binding TotalCheque, Mode=OneWay, StringFormat=R$ {0:N2}}"
                                TextAlignment="Right" />

                            <!--  Voucher  -->
                            <TextBlock
                                Grid.Row="7"
                                Grid.Column="0"
                                Text="Voucher :" />
                            <TextBlock
                                Grid.Row="7"
                                Grid.Column="1"
                                Margin="5,0,0,0"
                                Text=""
                                TextAlignment="Right" />
                            <TextBox
                                Grid.Row="7"
                                Grid.Column="2"
                                BorderThickness="0"
                                Text="{Binding ValorAbertura, Mode=OneWay, StringFormat=R$ {0:N2}}"
                                TextAlignment="Right" />

                            <!--  Linha divisória  -->
                            <Border
                                Grid.Row="8"
                                Grid.ColumnSpan="3"
                                Height="1"
                                Margin="0,10,0,10"
                                Background="Gray" />

                            <!--  Título: Resumo Financeiro  -->
                            <TextBlock
                                Grid.Row="9"
                                Grid.Column="0"
                                FontSize="13"
                                FontWeight="Bold"
                                Text="Resumo Financeiro" />

                            <!--  Suprimentos  -->
                            <TextBlock
                                Grid.Row="10"
                                Grid.Column="0"
                                Text="Suprimentos :" />
                            <TextBlock
                                Grid.Row="10"
                                Grid.Column="1"
                                Margin="5,0,0,0"
                                Text=""
                                TextAlignment="Right" />
                            <TextBox
                                Grid.Row="10"
                                Grid.Column="2"
                                BorderThickness="0"
                                Text="{Binding ValorAbertura, Mode=OneWay, StringFormat=R$ {0:N2}}"
                                TextAlignment="Right" />

                            <!--  Sangrias  -->
                            <TextBlock
                                Grid.Row="11"
                                Grid.Column="0"
                                Text="Sangrias :" />
                            <TextBlock
                                Grid.Row="11"
                                Grid.Column="1"
                                Margin="5,0,0,0"
                                Text=""
                                TextAlignment="Right" />
                            <TextBox
                                Grid.Row="11"
                                Grid.Column="2"
                                BorderThickness="0"
                                Text="{Binding TotalCheque, Mode=OneWay, StringFormat=R$ {0:N2}}"
                                TextAlignment="Right" />

                            <!--  Total em Caixa  -->
                            <TextBlock
                                Grid.Row="12"
                                Grid.Column="0"
                                FontWeight="Bold"
                                Text="Total em Caixa (Dinheiro) :" />
                            <TextBlock
                                Grid.Row="12"
                                Grid.Column="1"
                                Margin="5,0,0,0"
                                FontWeight="Bold"
                                Text=""
                                TextAlignment="Right" />
                            <TextBox
                                Grid.Row="12"
                                Grid.Column="2"
                                BorderThickness="0"
                                FontWeight="Bold"
                                Text="{Binding TotalCaixal, Mode=OneWay, StringFormat=R$ {0:N2}}"
                                TextAlignment="Right" />

                            <!--  Botão Fechar Caixa  -->
                            <Button
                                x:Name="BtnFecharCaixa"
                                Grid.Row="13"
                                Grid.ColumnSpan="3"
                                Margin="0,18,0,0"
                                Click="BtnFecharCaixa_Click"
                                Content="🔒 FECHAR CAIXA"
                                Style="{StaticResource RoundedRedButton}" />

                            <!--  Botão Finalizar Compra  -->
                            <Button
                                x:Name="BtnFinalizarCompra"
                                Grid.Row="14"
                                Grid.ColumnSpan="3"
                                Margin="0,12,0,0"
                                Click="BtnFinalizarCompra_Click"
                                Content="FINALIZAR COMPRA"
                                Style="{StaticResource RoundedBlueButton}" />

                        </Grid>
                    </Border>
                </StackPanel>

            </Grid>
        </DockPanel>
    </Grid>
</UserControl>
