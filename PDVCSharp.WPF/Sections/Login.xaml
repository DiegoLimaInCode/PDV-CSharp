<UserControl x:Class="PDVCSharp.WPF.Sections.Login"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PDVCSharp.WPF.Sections"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <StackPanel Margin="40" MaxWidth="500">
        <TextBlock  Text="Login" FontSize="40" FontWeight="SemiBold" />
        <Grid Margin="0 0 0 20" MaxWidth="500">
            <TextBox x:Name="TxtUsuario" 
             FontSize="40" 
             Foreground="#333" />

            <TextBlock x:Name="PlaceholderUsuario"
               Text="Usuário"
               FontSize="40"
               Foreground="Gray"
               IsHitTestVisible="False"
               VerticalAlignment="Center"
               Margin="10,0,0,0"
               Visibility="Visible"/>
        </Grid>
        <Grid Margin="0 0 0 40" MaxWidth="500">
            <PasswordBox x:Name="TxtPassword" 
                 FontSize="40" 
                 Foreground="#333" 
                 PasswordChanged="TxtPassword_PasswordChanged"/>

            <TextBlock x:Name="PlaceholderText"
               Text="Senha" 
               FontSize="40" 
               Foreground="Gray" 
               IsHitTestVisible="False" 
               VerticalAlignment="Center" 
               Margin="10,0,0,0"
               Visibility="Visible"/>
        </Grid>
        <Button Content="Login" Width="100" Height="30" Click="Button_Click"/>

    </StackPanel>
</UserControl>
