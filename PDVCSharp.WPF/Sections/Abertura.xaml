<UserControl
    x:Class="PDVCSharp.WPF.Sections.Abertura"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:PDVCSharp.WPF.Sections"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:PDVCSharp.WPF.ViewModels"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <UserControl.DataContext>
        <vm:AberturaViewModel />
    </UserControl.DataContext>

    <Grid>
        <DockPanel>

            <StackPanel Background="#FFEAE5E5">

                <Border
                    Height="30"
                    Background="#FF4B4747"
                    CornerRadius="0">
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="White"
                        Text="CAIXA - 01" />
                </Border>


                <TextBlock
                    Margin="0,130,0,0"
                    FontSize="40"
                    FontWeight="ExtraBold"
                    Foreground="#FF404040"
                    TextAlignment="Center">
                    <Run Text="Abertura De Caixa" /></TextBlock>

                <StackPanel
                    Margin="0,-10,0,0"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal">
                    <TextBlock
                        FontFamily="Sans Serif Collection"
                        FontSize="17"
                        FontWeight="Thin"
                        Foreground="#666"
                        TextAlignment="Center">
                        <Run Text="Operador: " />
                        <Run FontWeight="SemiBold" Text="{Binding OperatorName, Mode=OneWay}" />
                    </TextBlock>

                    <TextBlock
                        Margin="20,0,0,0"
                        FontFamily="Sans Serif Collection"
                        FontSize="17"
                        FontWeight="Thin"
                        Foreground="#666"
                        TextAlignment="Center">
                        <Run Text="Data: " />
                        <Run FontWeight="SemiBold" Text="{Binding Today, Mode=OneWay, StringFormat={}{0:dd/MM/yyyy}}" />
                    </TextBlock>
                </StackPanel>

                <TextBlock
                    Margin="-40,0,0,0"
                    FontSize="13"
                    FontWeight="Bold"
                    TextAlignment="Center">
                    <Run Text="Informe o valor de abertura deste caixa:" />
                </TextBlock>
                <Grid Margin="80,0,0,0">
                    <Border
                        Width="275"
                        Height="50"
                        Margin="-90,15,0,0"
                        HorizontalAlignment="Center"
                        BorderBrush="Gray"
                        BorderThickness="1"
                        CornerRadius="10">
                        <Grid>

                            <TextBox
                                x:Name="PlaceHolder_ValueBox"
                                Padding="10,0"
                                HorizontalContentAlignment="Left"
                                VerticalContentAlignment="Center"
                                Background="Transparent"
                                BorderThickness="0"
                                CaretBrush="Black"
                                FontSize="18"
                                FontWeight="Bold"
                                Foreground="Transparent"
                                TextChanged="PlaceHolder_ValueBox_TextChanged" />

                            <TextBlock
                                Margin="10,10,20,6"
                                FontSize="18"
                                FontWeight="Bold"
                                IsHitTestVisible="False">
                                <TextBlock.Foreground>
                                    <SolidColorBrush Opacity="0.5" Color="Gray" />
                                </TextBlock.Foreground>
                                <Run x:Name="TxtValorEntrada" Text="0,00" />
                            </TextBlock>


                        </Grid>
                    </Border>
                </Grid>
                <Grid>
                    <Border
                        Width="250"
                        Height="50"
                        Margin="290,20,300,-75"
                        HorizontalAlignment="Center"
                        Background="#FF1A4D99"
                        CornerRadius="10">

                        <Button
                            x:Name="ButtonConfirm"
                            Margin="0,0,0,0"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="BtnConfirmar_Click"
                            Content="Confirmar valor"
                            Cursor="Hand"
                            FontSize="18"
                            Foreground="White" />
                    </Border>

                </Grid>



            </StackPanel>

        </DockPanel>

        <StackPanel
            x:Name="AdminOperatorArea"
            Margin="0,55,30,0"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Panel.ZIndex="10"
            Visibility="Collapsed">
            <Border
                Width="170"
                Height="42"
                Background="#FF1A4D99"
                CornerRadius="10">
                <Button
                    Background="Transparent"
                    BorderThickness="0"
                    Click="BtnToggleOperatorPanel_Click"
                    Content="Novo operador"
                    Cursor="Hand"
                    FontSize="15"
                    FontWeight="SemiBold"
                    Foreground="White" />
            </Border>

            <Border
                x:Name="AdminOperatorPanel"
                Width="330"
                Margin="0,12,0,0"
                Padding="18,16"
                Background="White"
                BorderBrush="#FFD7D7D7"
                BorderThickness="1"
                CornerRadius="12"
                Visibility="Collapsed">
                <StackPanel>
                    <TextBlock
                        FontSize="16"
                        FontWeight="Bold"
                        Foreground="#FF404040"
                        Text="Cadastrar operador" />

                    <TextBlock
                        Margin="0,14,0,6"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Foreground="#FF666666"
                        Text="Nome" />
                    <TextBox
                        x:Name="TxtOperatorName"
                        Height="36"
                        Padding="10,0"
                        VerticalContentAlignment="Center"
                        BorderBrush="#FFC8C8C8"
                        BorderThickness="1"
                        Text="" />

                    <TextBlock
                        Margin="0,12,0,6"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Foreground="#FF666666"
                        Text="Login" />
                    <TextBox
                        x:Name="TxtOperatorLogin"
                        Height="36"
                        Padding="10,0"
                        VerticalContentAlignment="Center"
                        BorderBrush="#FFC8C8C8"
                        BorderThickness="1"
                        Text="" />

                    <TextBlock
                        Margin="0,12,0,6"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Foreground="#FF666666"
                        Text="Cargo" />
                    <ComboBox
                        x:Name="CmbOperatorCargo"
                        Height="36"
                        Padding="8,0"
                        SelectedIndex="0">
                        <ComboBoxItem Content="Caixa" Tag="Caixa" />
                        <ComboBoxItem Content="Administrador" Tag="Administrador" />
                    </ComboBox>

                    <TextBlock
                        Margin="0,12,0,6"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Foreground="#FF666666"
                        Text="Senha" />
                    <PasswordBox
                        x:Name="PwdOperator"
                        Height="36"
                        Padding="10,0"
                        VerticalContentAlignment="Center" />

                    <StackPanel
                        Margin="0,16,0,0"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal">
                        <Button
                            Width="84"
                            Height="34"
                            Margin="0,0,8,0"
                            Background="#FFF3F3F3"
                            BorderBrush="#FFD0D0D0"
                            BorderThickness="1"
                            Click="BtnCloseOperatorPanel_Click"
                            Content="Fechar"
                            Cursor="Hand"
                            Foreground="#FF404040" />
                        <Button
                            x:Name="BtnSaveOperator"
                            Width="84"
                            Height="34"
                            Margin="0,0,8,0"
                            Background="#FF1A4D99"
                            BorderThickness="0"
                            Click="BtnSaveOperator_Click"
                            Content="Salvar"
                            Foreground="White" />
                        <Button
                            Width="106"
                            Height="34"
                            Background="#FFB71C1C"
                            BorderThickness="0"
                            Click="BtnToggleDeleteOperatorPanel_Click"
                            Content="Excluir usuário"
                            Cursor="Hand"
                            Foreground="White" />
                    </StackPanel>

                    <Border
                        x:Name="DeleteOperatorPanel"
                        Margin="0,14,0,0"
                        Padding="10"
                        Background="#FFF7F7F7"
                        BorderBrush="#FFE0E0E0"
                        BorderThickness="1"
                        CornerRadius="8"
                        Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="#FF555555"
                                Text="Selecione o usuário para excluir" />

                            <ComboBox
                                x:Name="CmbUsersToDelete"
                                Height="36"
                                Margin="0,10,0,0"
                                Padding="8,0" />

                            <Button
                                Width="120"
                                Height="34"
                                Margin="0,12,0,0"
                                HorizontalAlignment="Right"
                                Background="#FFB71C1C"
                                BorderThickness="0"
                                Click="BtnDeleteOperator_Click"
                                Content="Deletar"
                                Cursor="Hand"
                                Foreground="White" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
        <TextBlock
            Margin="0,5,45,0"
            FontSize="10"
            Foreground="White"
            IsHitTestVisible="False"
            Text="📶"
            TextAlignment="Right" />
        <TextBlock
            x:Name="TxtHora"
            Margin="0,5,0,0"
            FontSize="10"
            Foreground="White"
            IsHitTestVisible="False"
            Text="{Binding Now, Mode=OneWay, StringFormat={}{0:HH:mm}}"
            TextAlignment="Right" />
        <TextBlock
            Margin="62,66,595,358"
            FontSize="20"
            FontWeight="Bold"
            Foreground="#2151A1"
            IsHitTestVisible="False"
            Text="SUPERMARKET" />
        <TextBlock
            Margin="28,63,738,355"
            FontSize="24"
            Foreground="#2151A1"
            IsHitTestVisible="False"
            RenderTransformOrigin="1.379,0.609"
            Text="🛒" />

    </Grid>
</UserControl>