<UserControl x:Class="PDVCSharp.WPF.Sections.Abertura"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PDVCSharp.WPF.Sections"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <Grid>
        <DockPanel>

            <StackPanel Background="#FFEAE5E5">

                <Border Background="#FF4B4747" Height="30" CornerRadius="0">
                    <TextBlock Text="CAIXA - 01" 
               Foreground="White" 
               FontSize="12" 
               HorizontalAlignment="Center" 
               VerticalAlignment="Center"/>
                </Border>


                <TextBlock FontSize="40" 
                       TextAlignment="Center" Margin="0,130,0,0" FontWeight="ExtraBold" 
                       Foreground="#FF404040">
                <Run Text="Abertura De Caixa"
                /></TextBlock>

                <TextBlock FontSize ="17" Margin="-200, -10, 0, 0" 
                       TextAlignment="Center"
                       FontFamily="Sans Serif Collection"
                       FontWeight="Thin">
                <Run Text="Operador: Bernardo"></Run>
                </TextBlock>

                <TextBlock FontWeight="Bold" FontSize="13" TextAlignment="Center" 
                       Margin="-110, 0, 0, 0">
                <Run Text="Informe o valor de abertura deste caixa:"></Run>
                </TextBlock>
                <Grid>
                    <Border CornerRadius="10" 
        BorderBrush="Gray" 
        BorderThickness="1"
        HorizontalAlignment="Center" 
        Width="275" 
        Height="50"
        Margin="-90, 15, 0, 0"                    >
                        <TextBox x:Name="PlaceHolder_ValueBox" 
            BorderThickness="0" 
            Background="Transparent"
            VerticalContentAlignment="Center"
            Padding="10,0"
            FontSize="18"
            FontWeight="Bold"
            Text="R$ 200,00"
            GotFocus="PlaceHolder_ValueBox_GotFocus"
            LostFocus="PlaceHolder_ValueBox_LostFocus"/>
                    </Border>
                </Grid>
                <Grid>
                    <Border CornerRadius="10" 
        Background="#FF1A4D99" 
        HorizontalAlignment="Center" 
        Width="250" 
        Height="50" 
        Margin="220,20,300,-75">

                        <Button x:Name="ButtonConfirm" 
            Content="Confirmar valor" 
            Background="Transparent" 
            BorderThickness="0" 
            Foreground="White"
            FontSize="18"
            Cursor="Hand"/>
                    </Border>

                </Grid>



            </StackPanel>
            
        </DockPanel>
        <TextBlock Text="📶" Foreground="White" FontSize="10" TextAlignment="Right" Margin="0, 5, 40 ,0" />
        <TextBlock x:Name="TxtHora" Text="00:00" Foreground="White" FontSize="10" TextAlignment="Right" Margin="0, 5, 10, 0"/>
        <TextBlock Text="SUPERMARKET" FontSize="20" FontWeight="Bold"
            Foreground="#2151A1" Margin="62,66,595,358" />
        <TextBlock Text="🛒" FontSize="24" Foreground="#2151A1" Margin="28,63,738,355" RenderTransformOrigin="1.379,0.609"/>





    </Grid>
</UserControl>